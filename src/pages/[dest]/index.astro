---
// Route destination — ARCHITECTURE §4
// getStaticPaths → une page par destination dans les collections
import { getCollection } from 'astro:content';
import DestinationLayout from '../../layouts/Destination.astro';
import Hero from '../../components/Hero.astro';
import Nav from '../../components/Nav.astro';
import Timeline from '../../components/Timeline.astro';
import ChapterCover from '../../components/ChapterCover.astro';
import Pullquote from '../../components/Pullquote.astro';
import Curatorial from '../../components/Curatorial.astro';
import InfoColumns from '../../components/InfoColumns.astro';
import PhotoGrid from '../../components/PhotoGrid.astro';
import Lightbox from '../../components/Lightbox.astro';
import AccomGrid from '../../components/AccomGrid.astro';
import FoodieBlock from '../../components/FoodieBlock.astro';
import GemBlock from '../../components/GemBlock.astro';
import MapSection from '../../components/MapSection.astro';
import BudgetSection from '../../components/BudgetSection.astro';
import PratiqueGrid from '../../components/PratiqueGrid.astro';
import ContainerSurvol from '../../components/ContainerSurvol.astro';
import { ui } from '../../lib/ui-strings';

export async function getStaticPaths() {
  const destinations = await getCollection('destinations');
  return destinations.map((entry) => ({ params: { dest: entry.data.slug } }));
}

const { dest } = Astro.params;

// Charger toutes les collections
const [allDestinations, allBases, allPois, allDishes, allGems, allBudget, allPratique, allImages] =
  await Promise.all([
    getCollection('destinations'),
    getCollection('bases'),
    getCollection('pois'),
    getCollection('dishes'),
    getCollection('gems'),
    getCollection('budget'),
    getCollection('pratique'),
    getCollection('images'),
  ]);

const destination = allDestinations.find((d) => d.data.slug === dest);
if (!destination) throw new Error(`Destination introuvable : ${dest}`);

// Filtrer par destination.
// Pour les bases (glob loader), Astro utilise data.slug comme ID quand présent.
// On filtre par filePath qui contient "/${dest}/" (plus fiable que le slug).
// Pour les arrays (destScopedArray), l'ID est "<dest>/<item.id>".
const bases = allBases
  .filter((b) => {
    const fp = (b as any).filePath as string | undefined;
    return fp ? fp.includes(`/${dest}/`) : b.id.startsWith(`${dest}/`);
  })
  .sort((a, b) => a.data.order - b.data.order);

const pois = allPois
  .filter((p) => p.id.startsWith(`${dest}/`))
  .map((p) => p.data);

// dishes / gems — entités éditoriales sans `base` (schema §3.4 : pas de champ base)
// Affichées après le tour des bases, une fois par destination
const dishes = allDishes
  .filter((d) => d.id.startsWith(`${dest}/`))
  .map((d) => d.data);

const gems = allGems
  .filter((g) => g.id.startsWith(`${dest}/`))
  .map((g) => g.data);

const imageManifest = allImages
  .filter((i) => i.id.startsWith(`${dest}/`))
  .map((i) => i.data);

const budgetEntry = allBudget.find((b) => b.id.startsWith(`${dest}/`));
const pratiqueEntry = allPratique.find((p) => p.id.startsWith(`${dest}/`));

const d = destination.data;
// `strings` (pas `t`) : `for (const t of c.tiles)` plus bas shadowerait `t`.
const strings = ui(d.lang);

// Résolution slot → URL d'asset buildée (hero + covers de chapitre).
// Échec = warning au build, pas de silence : un slot référencé qui ne résout pas est un bug de contenu.
const pageAssets = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/**/*.{jpg,jpeg,png,webp}',
  { eager: true }
);
function resolveSlot(slot: string | null | undefined): string | undefined {
  if (!slot) return undefined;
  const entry = imageManifest.find((i) => i.slot === slot);
  if (!entry) {
    console.warn(`[images] ${dest}: slot "${slot}" absent du manifest images.json`);
    return undefined;
  }
  const mod = pageAssets[`/src/assets/destinations/${dest}/${entry.file}`];
  if (!mod) {
    console.warn(`[images] ${dest}: fichier "${entry.file}" introuvable dans src/assets (slot "${slot}")`);
    return undefined;
  }
  return mod.default.src;
}
const heroImageUrl = resolveSlot(d.hero.image);

// Crédit/attribution d'un slot (auteur + licence) — pour Hero et ChapterCover (images de fond).
function resolveCredit(slot: string | null | undefined) {
  if (!slot) return undefined;
  return imageManifest.find((i) => i.slot === slot)?.credit;
}
const heroCredit = resolveCredit(d.hero.image);

const totalNights =
  d.departure && d.arrival
    ? Math.round(
        (new Date(d.departure.date).getTime() - new Date(d.arrival.date).getTime()) / 86400000
      )
    : 30;

// Groupes éditoriaux (dish.group / gem.group = titre du bloc v1, un bloc rendu par groupe)
function groupsOf(items: Array<{ group?: string }>): Array<string | undefined> {
  const seen: Array<string | undefined> = [];
  for (const it of items) if (!seen.includes(it.group)) seen.push(it.group);
  return seen;
}
const dishGroups = groupsOf(dishes);
const gemGroups = groupsOf(gems);

// ——— ADR-5 : le CONTAINER « survol » (rendu si episodic=true) ———
// Fourchette budget pour la grille factuelle : 1er → dernier scénario (serré → confort+),
// chiffres nettoyés pour une fourchette condensée. Repli sur le total si pas de scénarios.
function budgetRange(b: any): string {
  const nums = (b?.scenarios ?? [])
    .map((s: any) => String(s.total ?? '').replace(/[^\d\s]/g, '').trim())
    .filter(Boolean);
  if (nums.length >= 2) return `${nums[0]} – ${nums[nums.length - 1]} $`;
  return b?.total ? String(b.total) : '';
}

let survol: any = null;
if (d.episodic && d.container) {
  // « live » = un épisode existe vraiment à <dest>/episodes/<base> (source de vérité unique).
  // Un chapitre annoncé sans épisode → tuile « à venir », jamais de lien mort.
  const allEpisodes = await getCollection('episodes');
  const episodeBases = new Set(
    allEpisodes
      .filter((e) => e.id.startsWith(`${dest}/episodes/`))
      .map((e) => e.id.split('/')[2])
  );
  const c = d.container;
  const facts: Array<{ value: string; label: string }> = [
    { value: d.season, label: strings.factSeason },
    { value: strings.factDays(totalNights), label: strings.factDuration },
    { value: `${d.arrival.airport} → ${d.departure.airport}`, label: strings.factFlight },
  ];
  const range = budgetRange(budgetEntry?.data);
  // Label dérivé de travelers.count (l'ancien « 2 pers. » codé dur mentait pour les voyages solo).
  if (range) facts.push({ value: range, label: strings.factBudget(d.travelers.count) });
  // Crédits photo (attribution légale CC) : image du hook + images de tuiles.
  const survolSlots = new Set<string>();
  if (c.hookImage) survolSlots.add(c.hookImage);
  for (const t of c.tiles) if (t.image) survolSlots.add(t.image);
  const imageCredits = [...survolSlots]
    .map((slot) => imageManifest.find((i) => i.slot === slot))
    .filter((i): i is NonNullable<typeof i> => !!i)
    .map((i) => ({ alt: i.alt, credit: i.credit }));
  survol = {
    hookKicker: c.hookKicker,
    hookTitle: c.hookTitle,
    hookBody: c.hookBody,
    hookImageUrl: resolveSlot(c.hookImage),
    facts,
    imageCredits,
    tilesIntro: c.tilesIntro,
    tiles: c.tiles.map((t) => {
      const live = episodeBases.has(t.base);
      return {
        href: live ? `/${dest}/${t.base}/` : null,
        kicker: t.kicker,
        title: t.title,
        teaser: t.teaser,
        imageUrl: t.image ? resolveSlot(t.image) : null,
        initial: (t.title || '·').trim().charAt(0).toUpperCase(),
        live,
      };
    }),
  };
}
---

{survol ? (
  <DestinationLayout
    title={d.pageTitle || `${d.heroTitle.main} — ${d.heroTitle.em} · Itinéraire`}
    favicon={d.theme.favicon}
    palette={d.theme.palette}
    description={d.subtitle}
    canonicalUrl={`https://chartrandapps.ca/${dest}/`}
    footerNote={d.footerNote}
    lang={d.lang}
  >
    <ContainerSurvol
      lang={d.lang}
      hookKicker={survol.hookKicker}
      hookTitle={survol.hookTitle}
      hookBody={survol.hookBody}
      hookImageUrl={survol.hookImageUrl}
      facts={survol.facts}
      tilesIntro={survol.tilesIntro}
      tiles={survol.tiles}
      imageCredits={survol.imageCredits}
    />
  </DestinationLayout>
) : (
<DestinationLayout
  title={d.pageTitle || `${d.heroTitle.main} — ${d.heroTitle.em} · Itinéraire`}
  favicon={d.theme.favicon}
  palette={d.theme.palette}
  description={d.subtitle}
  canonicalUrl={`https://chartrandapps.ca/${dest}/`}
  footerNote={d.footerNote}
  lang={d.lang}
>
  <Hero
    heroTitle={d.heroTitle}
    heroSub={d.heroSub}
    hero={d.hero}
    travelers={d.travelers}
    arrival={d.arrival}
    departure={d.departure}
    season={d.season}
    imageUrl={heroImageUrl}
    credit={heroCredit}
  />

  <Nav bases={bases.map((b) => ({ slug: b.data.slug, title: b.data.title }))} dest={dest} />

  <main id="main-content">

    <!-- VUE D'ENSEMBLE — trois éléments v1 : .section-num + h2.section-title + p.section-intro -->
    <div id="vue" class="tab-section">
      <div class="section">
        <div class="container">
          <div class="section-header reveal">
            <span class="section-num">{d.overviewKicker}</span>
            <h2 class="section-title">{d.overviewTitle}</h2>
            <p class="section-intro">{d.overviewIntro}</p>
          </div>
          <Timeline bases={bases.map((b) => b.data)} />

          <!-- intro-grid v1 : « Pourquoi septembre » / « Logistique de base » -->
          <div class="intro-grid">
            <div class="intro-block">
              <div class="intro-block-title">{d.intro.whySeason.title}</div>
              <div class="intro-block-body">{d.intro.whySeason.body}</div>
            </div>
            <div class="intro-block">
              <div class="intro-block-title">{d.intro.logistics.title}</div>
              <div class="intro-block-body">{d.intro.logistics.body}</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- BASES — une section par base (ordre préservé) -->
    {bases.map((base) => {
      const bd = base.data;
      // POIs de cette base (pois.json utilise base: "<slug>")
      const basePois = pois.filter((p) => p.base === bd.slug);

      return (
        <div id={bd.slug} class="tab-section">
          <ChapterCover
            title={bd.title}
            subtitle={bd.subtitle}
            kicker={bd.kicker}
            order={bd.order}
            totalBases={bases.length}
            dates={bd.dates}
            nights={bd.nights}
            imageUrl={resolveSlot(bd.cover)}
            credit={resolveCredit(bd.cover)}
          />

          <Pullquote text={bd.pullquote} />

          <div class="section">
            <div class="container">

              {/* Curatorial — prose Markdown avec [[poi:]] résolus */}
              <Curatorial
                body={base.body ?? ''}
                pois={basePois}
              />

              {/* tagBlock — absent si null/undefined → pas de markup vide */}
              {bd.tagBlock && (
                <div class="tag-block reveal">
                  <span class="map-label">{bd.tagBlock.label}</span>
                  <div class="tag-list">
                    {bd.tagBlock.tags.map((tag) => (
                      <span class:list={['tag', tag.tone && tag.tone]}>{tag.text}</span>
                    ))}
                  </div>
                </div>
              )}

              {/* access — optionnel (Loutro, Cappadoce...) */}
              {bd.access && (
                <div class="note-box reveal">
                  <strong>Comment y accéder</strong>
                  <p>{bd.access.body}</p>
                  {bd.access.links && bd.access.links.length > 0 && (
                    <div class="link-row" style="margin-top: 8px;">
                      {bd.access.links.map((l) => (
                        <a class="link-pill" href={l.url} target="_blank" rel="noopener">{l.label}</a>
                      ))}
                    </div>
                  )}
                </div>
              )}

              {/* notes */}
              {bd.notes && bd.notes.map((note) => (
                <div class="note-box reveal">
                  <strong>{note.kind}</strong>
                  <p>{note.body}</p>
                </div>
              ))}

              {/* InfoColumns — composition ordonnée, ordre PRÉSERVÉ */}
              <InfoColumns infoBlocks={bd.infoBlocks} pois={basePois} />

              {/* PhotoGrid — photos de grille de CETTE base (champ base du manifest ; cover/accom/food rendus ailleurs) */}
              <PhotoGrid
                slots={imageManifest
                  .filter((img) => img.base === bd.slug && img.role === 'photo')
                  .map((img) => img.slot)}
                imageManifest={imageManifest}
                dest={dest}
              />

              {/* AccomGrid — POIs avec role sleep, triés par tier + cartes v1 hors MAPS (accomExtras) */}
              <AccomGrid pois={basePois} extras={bd.accomExtras} imageManifest={imageManifest} dest={dest} />

              {/* MapSection vanilla Leaflet (FR-4) */}
              <MapSection pois={basePois} baseSlug={bd.slug} label={bd.mapLabel} />

            </div>
          </div>
        </div>
      );
    })}

    <!-- FoodieBlock — entités éditoriales (dishes.json, §3.4) — un bloc par groupe v1 -->
    {dishes.length > 0 && (
      <div class="tab-section">
        <div class="section">
          <div class="container">
            {dishGroups.map((g) => (
              <FoodieBlock
                dishes={dishes.filter((di) => di.group === g) as any[]}
                title={g}
                imageManifest={imageManifest}
                dest={dest}
              />
            ))}
          </div>
        </div>
      </div>
    )}

    <!-- GemBlock — entités éditoriales (gems.json, §3.4) — un bloc par groupe v1 -->
    {gems.length > 0 && (
      <div class="tab-section">
        <div class="section">
          <div class="container">
            {gemGroups.map((g) => (
              <GemBlock
                gems={gems.filter((ge) => ge.group === g) as any[]}
                title={g}
                imageManifest={imageManifest}
                dest={dest}
              />
            ))}
          </div>
        </div>
      </div>
    )}

    <!-- BudgetSection -->
    {budgetEntry && (
      <BudgetSection
        budget={budgetEntry.data}
        totalNights={totalNights}
        travelers={d.travelers.count}
      />
    )}

    <!-- PratiqueGrid -->
    {pratiqueEntry && (
      <PratiqueGrid pratique={pratiqueEntry.data} />
    )}

  </main>

  <Lightbox />

</DestinationLayout>
)}

<style>
  /* intro-grid v1 (vue d'ensemble) */
  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 24px;
  }

  .intro-block {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 22px 24px;
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .intro-block:hover { box-shadow: var(--shadow-sm); transform: translateY(-1px); }

  .intro-block-title {
    font-weight: 500;
    font-size: 14px;
    margin-bottom: 10px;
    color: var(--text);
  }

  .intro-block-body { font-size: 13px; color: var(--muted); line-height: 1.75; }

  @media (max-width: 640px) { .intro-grid { grid-template-columns: 1fr; } }

  .tag-block { margin: 24px 0; }

  .map-label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--terre);
    margin-bottom: 6px;
    display: block;
  }

  .tag-list { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 6px; }

  .tag {
    font-size: 12px;
    padding: 4px 12px;
    border-radius: 6px;
    background: var(--mer-light);
    color: var(--mer);
    font-weight: 400;
  }

  .tag.amber { background: #FEF3E2; color: #8B5516; }
  .tag.green { background: #EAF5E9; color: #256B2F; }

  .note-box {
    margin-top: 20px;
    padding: 16px 20px;
    background: var(--sand);
    border-radius: var(--radius-sm);
    font-size: 13px;
    color: var(--muted);
    line-height: 1.7;
    border-left: 3px solid var(--terre);
  }

  .note-box strong { color: var(--text); font-weight: 500; }

  .link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .link-pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    padding: 3px 10px;
    border-radius: 20px;
    background: var(--mer-light);
    color: var(--mer);
    text-decoration: none;
    transition: all var(--transition);
    font-weight: 400;
  }

  .link-pill:hover { background: var(--mer); color: white; }
</style>
