<script>
  // ——— Toggle Épisode / Carnet (sous-nav par intention) ———
  const proto = document.getElementById('proto')!;
  function setMode(mode: string) {
    proto.dataset.view = mode;
    document.querySelectorAll<HTMLButtonElement>('.mode-btn').forEach((b) => {
      b.setAttribute('aria-pressed', String(b.dataset.mode === mode));
    });
    window.scrollTo({ top: 0, behavior: 'auto' });
    if (history.replaceState) history.replaceState(null, '', mode === 'carnet' ? '#carnet' : '#');
    try {
      localStorage.setItem('proto-chania-mode', mode);
    } catch {}
    document.dispatchEvent(new CustomEvent('proto:modechange', { detail: mode }));
  }
  document.querySelectorAll<HTMLElement>('[data-mode]').forEach((el) => {
    if (el.tagName === 'BUTTON') el.addEventListener('click', () => setMode(el.dataset.mode!));
  });

  // (La hauteur de la topbar est FIXE en CSS — la mesure JS au chargement attrapait
  // le wrap temporaire des fontes fallback → carte 70px trop basse, vu sur iPhone.)
  // Usage répété : on rouvre dans le dernier mode utilisé (le hash explicite gagne).
  let storedMode: string | null = null;
  try {
    storedMode = localStorage.getItem('proto-chania-mode');
  } catch {}
  if (location.hash === '#carnet' || storedMode === 'carnet') setMode('carnet');

  // ——— Barre de progression (A Trail Tale, version sobre) ———
  const fill = document.getElementById('progress-fill');
  if (fill) {
    const onScroll = () => {
      const h = document.documentElement;
      const max = h.scrollHeight - h.clientHeight;
      fill.style.width = max > 0 ? `${(h.scrollTop / max) * 100}%` : '0%';
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // ——— Cartes Leaflet : cold open + montage (scrolly) et mini-carte du carnet ———
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const parseBounds = (s: string) =>
    s.split(';').map((pair) => pair.split(',').map(Number) as [number, number]);

  import('leaflet').then(({ default: L }) => {
    const GLYPHS: Record<string, string> = { hotel: '🏨', resto: '🍽️', plage: '🏖️', sight: '🏛️' };

    type MarkerData = { id: string; name: string; mapType: string; coords: { lat: number; lng: number } };

    // Carte non interactive : décor piloté par le scroll, pas un widget.
    function buildMap(el: HTMLElement) {
      const markers: MarkerData[] = JSON.parse(el.dataset.markers ?? '[]');
      const map = L.map(el, {
        zoomControl: false,
        dragging: false,
        scrollWheelZoom: false,
        doubleClickZoom: false,
        boxZoom: false,
        keyboard: false,
        touchZoom: false,
        attributionControl: true,
      });
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        maxZoom: 19,
      }).addTo(map);

      const markerById = new Map<string, ReturnType<typeof L.marker>>();
      const coordsById = new Map<string, [number, number]>();
      markers.forEach((m) => {
        const glyph = GLYPHS[m.mapType] ?? '📍';
        const icon = L.divIcon({
          html: `<span class="map-glyph" aria-label="${m.mapType}">${glyph}</span>`,
          className: 'map-marker',
          iconSize: [32, 32],
          iconAnchor: [16, 16],
        });
        const marker = L.marker([m.coords.lat, m.coords.lng], { icon }).addTo(map);
        // Tooltip permanente JAMAIS fermée côté Leaflet (bug connu : une tooltip
        // permanent fermée se rouvre après un zoom — vécu sur iPhone, les 15 d'un
        // coup). On la laisse « ouverte » et on contrôle la visibilité en CSS.
        marker.bindTooltip(m.name, {
          permanent: true,
          direction: 'top',
          offset: [0, -16],
          className: 'map-tip tip-hidden',
        });
        markerById.set(m.id, marker);
        coordsById.set(m.id, [m.coords.lat, m.coords.lng]);
      });

      // Focus par beat/rangée : halo + nom sur les cibles, les autres estompés
      function focusTargets(ids: string[]) {
        const hasFocus = ids.length > 0;
        markerById.forEach((marker, id) => {
          const active = ids.includes(id);
          marker.setOpacity(hasFocus && !active ? 0.35 : 1);
          const el2 = marker.getElement();
          if (el2) el2.classList.toggle('is-active', active);
          const tipEl = marker.getTooltip()?.getElement();
          if (tipEl) tipEl.classList.toggle('tip-hidden', !active);
        });
      }

      const openBounds = parseBounds(el.dataset.openBounds ?? '');
      const fitOpen = () => map.fitBounds(L.latLngBounds(openBounds), { padding: [40, 40] });
      fitOpen();
      new ResizeObserver(() => map.invalidateSize()).observe(el);
      if (document.readyState !== 'complete') {
        window.addEventListener('load', () => { map.invalidateSize(); fitOpen(); }, { once: true });
      }
      return { map, focusTargets, coordsById, fitOpen, openBounds };
    }

    // — Sections scrollytellées (cold open + montage), chacune sa carte et ses beats.
    // Activation quand la CARTE DE TEXTE entre dans la bande centrale — pas le
    // conteneur .beat (90svh) : en scroll rapide la caméra volait vers le beat
    // suivant pendant que le texte affiché était encore le précédent (vérifié pinchtab).
    // Mobile : la carte de texte occupe le bas de l'écran — on décale la cible du
    // flyTo vers le bas pour que le marker + son étiquette atterrissent dans le
    // HAUT visible, au-dessus de la carte (feedback iPhone : « les cartes cachent
    // le fan out »). Bounds : padding bas asymétrique, même raison.
    const mobile = window.matchMedia('(max-width: 640px)').matches;

    document.querySelectorAll<HTMLElement>('.scrolly-map').forEach((section) => {
      const mapEl = section.querySelector<HTMLElement>('.scene-map');
      if (!mapEl) return;
      const { map, focusTargets, fitOpen, openBounds } = buildMap(mapEl);
      const flyOpts = { duration: reduced ? 0 : 1.6 };

      function flyPoint(lat: number, lng: number, zoom: number) {
        let center: any = [lat, lng];
        if (mobile) {
          const px = map.project([lat, lng], zoom).add([0, map.getSize().y * 0.18] as any);
          center = map.unproject(px, zoom);
        }
        reduced ? map.setView(center, zoom) : map.flyTo(center, zoom, flyOpts);
      }
      function flyBounds(b: ReturnType<typeof L.latLngBounds>, base: number) {
        const pad = mobile
          ? { paddingTopLeft: [30, 70] as any, paddingBottomRight: [30, Math.round(map.getSize().y * 0.38)] as any }
          : { padding: [base, base] as any };
        reduced ? map.fitBounds(b, pad) : map.flyToBounds(b, { ...pad, ...flyOpts });
      }

      const beatObs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const el = (entry.target as HTMLElement).closest<HTMLElement>('.beat')!;
            focusTargets((el.dataset.targets ?? '').split(',').filter(Boolean));
            if (el.dataset.fly) {
              const [lat, lng, zoom] = el.dataset.fly.split(',').map(Number);
              flyPoint(lat, lng, zoom);
            } else if (el.dataset.bounds) {
              flyBounds(L.latLngBounds(parseBounds(el.dataset.bounds)), 60);
            } else {
              flyBounds(L.latLngBounds(openBounds), 40);
            }
          });
        },
        { rootMargin: '-35% 0px -35% 0px' }
      );
      section
        .querySelectorAll<HTMLElement>('.beat')
        .forEach((b) => beatObs.observe(b.querySelector('.beat-card, .beat-quote') ?? b));
    });

    // — Mini-carte du carnet : suit le scroll de la liste (browse spatial rapide).
    // Init paresseuse : Leaflet dans un conteneur display:none mesure 0×0.
    let carnetReady = false;
    function initCarnetMap() {
      if (carnetReady) return;
      const el = document.getElementById('carnet-map');
      // offsetParent est null pour un élément fixed → on teste le MODE, pas le layout
      if (!el || proto.dataset.view !== 'carnet') return;
      carnetReady = true;
      const { map, focusTargets, coordsById } = buildMap(el);
      setTimeout(() => map.invalidateSize(), 400); // conteneur fixed + iOS : recale les tuiles
      const rowObs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const id = (entry.target as HTMLElement).dataset.poi!;
            focusTargets([id]);
            const c = coordsById.get(id);
            if (c) map.setView(c, Math.max(map.getZoom(), 12), { animate: !reduced });
          });
        },
        { rootMargin: '-30% 0px -55% 0px' }
      );
      document.querySelectorAll<HTMLElement>('[data-poi]').forEach((r) => rowObs.observe(r));
    }
    document.addEventListener('proto:modechange', (e) => {
      if ((e as CustomEvent).detail === 'carnet') initCarnetMap();
    });
    initCarnetMap(); // si la page s'ouvre déjà en mode carnet (hash ou mémoire)
  });
</script>

