---
// PROTOTYPE v3 — « mode épisode » — UN chapitre : Chania.
// Route isolée (/proto/chania/), ne touche pas au rendu v2 (/crete/).
// Depuis ADR-6 (v3-generalisation-decisions.md) : le shell (topbar/script/CSS) vit dans
// EpisodeLayout, les sections dans src/components/episode/. CETTE page = composition
// éditoriale du chapitre (jugement Bourdain) + résolution d'images, rien d'infra.
// Critère #5 : tout le texte vient du contenu existant (bases/01-chania.md, pois/dishes/gems).
// ADR-7 : l'infra (chargement, resolveSlot, poiPills, byKind, toBeat, carnetRow…) vit
// dans ../../lib/episode ; cette page ne garde que l'éditorial.
import EpisodeLayout from '../../layouts/EpisodeLayout.astro';
import ScrollyMapSection from '../../components/episode/ScrollyMapSection.astro';
import SceneSection from '../../components/episode/SceneSection.astro';
import CarnetSection from '../../components/episode/CarnetSection.astro';
import { createEpisode, type Pill, type CarnetRow } from '../../lib/episode';

// Vignettes des rangées du carnet (feedback Martin : « une photo alléchante,
// ça met 1 000 000 fois plus de valeur »). Pixel-vérifiées, override proto —
// les POI restos ont image:null au contenu et le slot accom-3 du Harismari
// pointe sur un festin de souvlakis (décalage manifest, voir README du rapport).
// Les alts du manifest sont décalés (faux vert vision-check) — on n'en hérite pas.
const carnetThumbs = {
  tamam: { slot: 'foodie-1', alt: 'Fromage frais et olives — table végétarienne' },
  chrisostomos: { slot: 'resto-1', alt: 'Côtelettes d’agneau grillées' },
  evgonia: { slot: 'resto-2', alt: 'Crevettes grillées, plateau de taverne' },
  'ntourountous-loukoumades': { slot: 'foodie-5', alt: 'Place 1866 au crépuscule' },
};

const {
  bd, pois, dishes: allDestDishes, gems: allDestGems,
  resolveSlot, poi, poiPills, toBeat, carnetRow,
  mapMarkers, allCoords, kmlCount, byKind, proseBlocks,
} = await createEpisode('crete', 'chania', { carnetThumbs });

const dishes = allDestDishes.filter((d) => (d.group ?? '').includes('Chania'));
const gems = allDestGems.filter((g) => (g.group ?? '').includes('Chania'));

// ——— Composition de l'épisode (jugement éditorial du prototype) ———
// Test Bourdain (EXPLORATION §1) : qui est derrière ? pourquoi ça compte ? on commande quoi ?
// Réponse complète → scène. Sinon → carnet.

const ntour = poi('ntourountous-loukoumades');
const tamam = poi('tamam');
const evgonia = poi('evgonia');

// Photos de scène ET vignettes choisies sur les PIXELS réels, pas sur les alts du
// manifest — le manifest chania a des alts décalés (photo-13 = feta/olives, pas
// loukoumades ; photo-12 = pommes, pas fruits de mer). Bug de contenu v2 à corriger
// séparément. `alt` explicite ici = description honnête de l'image réelle (additif).
// Rythme resserré (feedback Martin) : 3 beats par scène — titre+intro, reco+liens, jalon.
// `via` = provenance créateur ({ label, url }) — le hook « Sonny en a fait un épisode ».
// Câblé mais VIDE : la règle de convergence interdit d'affirmer une couverture sans
// vérification du contenu vidéo. Sera alimenté par le pipeline de sourcing v3
// (Wiens a couvert Chania en 2017 — premier candidat à vérifier par transcript).
const scenes = [
  {
    id: 'scene-ntourountous',
    num: 1,
    kicker: 'Place 1866',
    title: 'La première bouchée',
    image: 'foodie-5',
    alt: 'Ruelle pavée au crépuscule, étal de fruits devant une épicerie',
    intro: 'Des loukoumades — beignets au miel chauds, recette familiale. Place 1866, au cœur de la ville.',
    reco: 'On commande quoi : les loukoumades, point. Travelers’ Choice, mais c’est la file de locaux qui dit vrai.',
    quote: 'C’est cinq euros et c’est la première bouchée qui dit : OK, on est en Crète.',
    via: null,
    pills: poiPills(ntour),
  },
  {
    id: 'scene-tamam',
    num: 2,
    kicker: 'Ruelle Zambelíou',
    title: 'Souper dans un hammam du XVIᵉ',
    image: 'foodie-1',
    alt: 'Fromage frais et olives de Kalamata — table végétarienne',
    intro: 'Tamam, l’incontournable. Des anciens bains turcs du XVIᵉ siècle devenus une table crétoise contemporaine.',
    reco: 'On commande quoi : le végétarien, remarquable — il ne ressemble à rien d’autre en ville. Réserver.',
    quote: null,
    via: null,
    pills: poiPills(tamam),
  },
  {
    id: 'scene-evgonia',
    num: 3,
    kicker: 'Milonogianni 120',
    title: 'Nektarios décide',
    image: 'photo-4',
    alt: 'Poisson entier et pieuvre grillés — plateau de taverne',
    intro: 'Evgonia, une taverne de quartier, loin du front de port. Pas de carte vedette : le menu, c’est l’arrivage du matin.',
    reco: 'Agneau, lapin, poisson frais, yogourt maison. Le proprio Nektarios guide les choix — laisse-le faire.',
    quote: 'Règle d’or : le premier rang de restos du port, on l’évite. Qualité divisée par deux, prix doublés.',
    via: null,
    pills: poiPills(evgonia),
  },
];

// Beats du cold open carte-scène (pattern NBC — EXPLORATION §1).
// data-fly = "lat,lng,zoom" · data-bounds = liste d'ids de POI à cadrer.
const splantzia = poi('splantzia-vieille-ville');
const neaChora = poi('nea-chora');
const seitan = poi('seitan-limania');
const falassarna = poi('falassarna');
const elafonisi = poi('elafonisi');
const balos = poi('balos');

// `targets` = POI mis en évidence pendant le beat (halo + nom affiché, les autres
// markers s'estompent) — feedback Martin : « je sais pas trop où regarder ».
// `thumb` = vignette dans la carte de texte (slot vérifié aux pixels réels).
const mapBeats = [
  {
    kicker: 'La base',
    body: 'À Splantzia ou Halepa, jamais au front de port : c’est 20 % moins cher, c’est là où les voisines sortent leur chaise à 18 h, et c’est à dix minutes à pied de tout.',
    fly: `${splantzia.coords.lat},${splantzia.coords.lng},15`,
    targets: ['splantzia-vieille-ville', 'halepa-hotel'],
    thumb: 'photo-9',
    thumbAlt: 'Maisons colorées d’un port grec, à travers la végétation',
    pills: [
      { label: 'Splantzia · Maps', url: splantzia.links.maps! },
      { label: 'Halepa · Maps', url: poi('halepa-hotel').links.maps! },
    ],
  },
  {
    kicker: 'La plage locale',
    body: 'Marcher dix minutes jusqu’à Nea Chora et faire des longueurs. Sable fin, eau cristalline, pas de touristes.',
    fly: `${neaChora.coords.lat},${neaChora.coords.lng},15`,
    targets: ['nea-chora'],
    thumb: 'photo-1',
    thumbAlt: 'Plage de sable et eau turquoise, vue aérienne',
    pills: poiPills(neaChora),
  },
  {
    kicker: 'L’ouest sauvage',
    body: 'Falassarna face au soleil couchant. Elafonisi pour le sable rose et l’eau peu profonde — y aller tôt. Balos par le bateau depuis Kissamos, pas par la route de montagne.',
    bounds: [falassarna, elafonisi, balos]
      .map((p) => `${p.coords.lat},${p.coords.lng}`)
      .join(';'),
    targets: ['falassarna', 'elafonisi', 'balos'],
    thumb: 'photo-3',
    thumbAlt: 'Lagune de Balos, vue aérienne',
    pills: [
      { label: 'Falassarna', url: falassarna.links.maps! },
      { label: 'Elafonisi', url: elafonisi.links.maps! },
      { label: 'Balos', url: balos.links.maps! },
    ],
  },
  {
    kicker: 'La crique secrète',
    body: 'Seitan Limania — eau tropicale entre les rochers. Peu de gens connaissent. L’eau commence à 24 °C début septembre et monte tout le mois.',
    fly: `${seitan.coords.lat},${seitan.coords.lng},14`,
    targets: ['seitan-limania'],
    thumb: 'photo-7',
    thumbAlt: 'Côte montagneuse et criques, vue aérienne',
    pills: poiPills(seitan),
  },
];

// ——— Le montage (feedback Martin : « browser le carnet dans l'épisode ») ———
// Un beat par GROUPE, pas par adresse — le trailer du carnet, pas son inventaire.
// La voix reste Bourdain : ce que la caméra a pas eu le temps de filmer.
const chrisostomos = poi('chrisostomos');
const halepa = poi('halepa-hotel');
const ionas = poi('ionas-boutique-hotel');
const manousakis = poi('manousakis-winery');
const karavitakis = poi('karavitakis-winery');
const profitiIlia = poi('profiti-ilia-tombeaux-venizelos');
const harismari = (bd.accomExtras ?? [])[0];

const montageBeats = [
  {
    kicker: 'La table qu’on a pas filmée',
    body: 'Chrisostomos — 13 fois primé. Four à bois, agneau ofto, pain maison. Ouvert mer–dim seulement : ça se planifie.',
    fly: `${chrisostomos.coords.lat},${chrisostomos.coords.lng},16`,
    targets: ['chrisostomos'],
    thumb: 'resto-1',
    thumbAlt: 'Côtelettes d’agneau grillées sur planche de bois',
    pills: poiPills(chrisostomos),
  },
  {
    kicker: 'Où on dort',
    body: 'Neuf chambres dans un vénitien-ottoman restauré chez Ionas, le calme local à Halepa — ou le Harismari, bâtiment de 1400, un musée vivant. Jamais au front de port.',
    bounds: [halepa, ionas].map((p) => `${p.coords.lat},${p.coords.lng}`).join(';'),
    targets: ['halepa-hotel', 'ionas-boutique-hotel'],
    thumb: 'photo-5',
    thumbAlt: 'Chambre blanche lumineuse, fenêtre ouverte',
    pills: [
      { label: 'Ionas · Maps', url: ionas.links.maps! },
      { label: 'Halepa · Maps', url: halepa.links.maps! },
      ...(harismari?.links?.length ? [{ label: 'Harismari · Booking', url: harismari.links[0].url }] : []),
    ],
  },
  {
    kicker: 'Le vin',
    body: 'Une journée dans les vignes — dégustation chez Manousakis ou Karavitakis, tsikoudia en digestif. Tour privé possible avec Chania Wine Tours.',
    bounds: [manousakis, karavitakis].map((p) => `${p.coords.lat},${p.coords.lng}`).join(';'),
    targets: ['manousakis-winery', 'karavitakis-winery'],
    thumb: 'foodie-3',
    thumbAlt: 'Panier de bouteilles de vin dans les vignes',
    pills: [
      { label: 'Manousakis · Maps', url: manousakis.links.maps! },
      { label: 'Karavitakis · Maps', url: karavitakis.links.maps! },
      { label: 'Chania Wine Tours', url: 'https://www.chaniawinetours.com/' },
    ],
  },
  {
    kicker: 'Le sunset des locaux',
    body: 'La colline du Prophète Élie — vue sur Chania, la baie de Souda et la mer Égée. Mieux que le phare pour les photos, et jamais la foule.',
    fly: `${profitiIlia.coords.lat},${profitiIlia.coords.lng},15`,
    targets: ['profiti-ilia-tombeaux-venizelos'],
    thumb: 'photo-8',
    thumbAlt: 'Terrasses illuminées sur les rochers, le soir',
    pills: poiPills(profitiIlia),
  },
];

// ——— Carnet (mode terrain — liste dense, liens directs) ———
// Les collections Astro sortent en ordre alphabétique d'id ; l'ordre éditorial
// vient des poi-lists d'infoBlocks (Tamam d'abord — « l'incontournable »).
const carnetGroups = [
  { label: 'Où dormir', items: byKind(['hotel']) },
  { label: 'Où manger', items: byKind(['resto']) },
  { label: 'Les plages', items: byKind(['plage']) },
  { label: 'À voir', items: byKind(['sight']) },
];

// ——— Transformation vers les shapes des composants (résolution d'images ici) ———
const coldOpenBeats = mapBeats.map(toBeat);
const montageComponentBeats = montageBeats.map(toBeat);

const sceneData = scenes.map((s) => ({
  id: s.id,
  num: s.num,
  kicker: s.kicker,
  title: s.title,
  imageSrc: resolveSlot(s.image),
  alt: s.alt,
  intro: s.intro,
  reco: s.reco,
  via: s.via,
  quote: s.quote,
  pills: s.pills,
}));

// Carnet : structure unifiée (listes + prose) pour CarnetSection.
const carnetListGroups = carnetGroups.map((g) => {
  const rows: CarnetRow[] = g.items.map(carnetRow);
  if (g.label === 'Où dormir') {
    for (const e of (bd.accomExtras ?? []) as any[]) {
      // override proto : le slot accom-3 du contenu = festin de souvlakis (manifest décalé)
      rows.push({
        thumbSrc: resolveSlot('photo-5'),
        thumbAlt: e.name,
        name: e.name,
        price: e.price || undefined,
        blurb: e.blurb,
        pills: (e.links ?? []) as Pill[],
        forcePillRow: true,
      });
    }
  }
  return {
    type: 'list' as const,
    title: g.label,
    rows,
    footer:
      g.label === 'Où manger'
        ? 'Règle d’or : éviter le premier rang de restos sur le port — qualité divisée par deux, prix doublés.'
        : undefined,
  };
});
const proseGroups = proseBlocks.map((b: any) => ({
  type: 'prose' as const,
  title: b.label as string,
  body: b.body as string,
  pills: (b.links ?? []) as Pill[],
}));
const dishesGroup = {
  type: 'list' as const,
  title: 'Incontournables foodie',
  rows: dishes.map((d) => ({
    thumbSrc: d.image ? resolveSlot(d.image) : undefined,
    thumbAlt: d.title,
    thumbFood: true,
    name: d.title,
    blurb: d.body,
    pills: (d.links ?? []) as Pill[],
  })) as CarnetRow[],
};
const gemsGroup = {
  type: 'list' as const,
  title: 'Pépites locales',
  rows: gems.map((g) => ({
    thumbSrc: g.image ? resolveSlot(g.image) : undefined,
    thumbAlt: g.title,
    name: g.title,
    blurb: g.body,
    pills: (g.links ?? []) as Pill[],
  })) as CarnetRow[],
};
const carnetAllGroups = [...carnetListGroups, ...proseGroups, dishesGroup, gemsGroup];
---

<EpisodeLayout
  title={`${bd.title} — épisode · prototype v3`}
  favicon="🏝️"
  palette="crete"
  description={bd.subtitle}
  destLabel="Crète"
  chapterNum={bd.order}
  chapterTotal={4}
  chapterTitle={bd.title}
  storageKey="proto-chania-mode"
>
  <div class="view-episode">

    <ScrollyMapSection
      ariaLabel="Cold open — la carte"
      markers={mapMarkers}
      openBounds={allCoords}
      mapId="scene-map"
      beats={coldOpenBeats}
    >
      <div class="beat beat-title">
        <div class="beat-card beat-card-title reveal">
          <span class="ep-kicker">Chapitre {bd.order} de 4 · {bd.nights} nuits · {bd.dates}</span>
          <h1 class="ep-title">{bd.title}</h1>
          <p class="ep-sub">{bd.subtitle}</p>
          <span class="scroll-hint" aria-hidden="true">↓</span>
        </div>
      </div>
    </ScrollyMapSection>

    <section class="jalon">
      <blockquote class="jalon-quote reveal">{bd.pullquote}</blockquote>
    </section>

    <SceneSection scenes={sceneData} />

    <ScrollyMapSection
      ariaLabel="Le montage — le reste du chapitre"
      markers={mapMarkers}
      openBounds={allCoords}
      beats={montageComponentBeats}
    >
      <div class="beat beat-title">
        <div class="beat-card beat-card-title reveal">
          <span class="ep-kicker">Le montage</span>
          <h2 class="montage-title">Ce que la caméra a pas eu le temps de filmer</h2>
        </div>
      </div>
    </ScrollyMapSection>

    <section class="outro">
      <div class="outro-inner reveal">
        <span class="ep-kicker">Le reste de Chania</span>
        <p class="outro-body">
          Le marché couvert, les plats à pister, les pépites qu’aucune carte peut montrer —
          le port à 5 h 30, la promenade du soir. Les {pois.length} lieux du chapitre,
          tous avec leurs liens, vivent dans le carnet.
        </p>
        <button type="button" class="outro-btn" data-mode="carnet">Ouvrir le carnet</button>
        <a class="outro-next" href="/crete/#loutro">Chapitre suivant — Loutro →</a>
      </div>
    </section>

  </div>

  <CarnetSection
    title={bd.title}
    dates={bd.dates}
    focus={bd.focus}
    kmlHref="/proto/chania.kml"
    kmlDownload="chania.kml"
    kmlCount={kmlCount}
    markers={mapMarkers}
    openBounds={allCoords}
    groups={carnetAllGroups}
  />
</EpisodeLayout>
