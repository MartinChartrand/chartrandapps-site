---
// PROTOTYPE v3 — « mode épisode » — UN chapitre : SÉVILLE (Andalousie).
// Route isolée (/proto/seville/), ne touche pas au rendu v2 (/andalousie/).
// CLONE FIDÈLE de proto/chania.astro — même structure/mécanique, SEULE l'info change.
// CETTE page = composition éditoriale du chapitre (grammaire Bourdain, cf.
// docs/v3-design-research/storyboard-bourdain-andalousie.md) + résolution d'images.
// Cold open = LA CONTRADICTION (joie sévillane / château de l'Inquisition).
// Beat de friction (Phase 4) = le jamón comme test religieux — voix de Martin.
//   ⚠ À SOURCER avant tout passage en [dest] : la consommation publique de porc comme
//   preuve de « limpieza de sangre » sous l'Inquisition est de l'histoire standard
//   (conversos/morisques), mais doit porter une source avant de quitter le proto.
// ADR-7 : l'infra (chargement, resolveSlot, poiPills, byKind, toBeat, carnetRow…) vit
// dans ../../lib/episode ; cette page ne garde que l'éditorial.
import EpisodeLayout from '../../layouts/EpisodeLayout.astro';
import ScrollyMapSection from '../../components/episode/ScrollyMapSection.astro';
import SceneSection from '../../components/episode/SceneSection.astro';
import CarnetSection from '../../components/episode/CarnetSection.astro';
import { createEpisode, type Pill, type CarnetRow } from '../../lib/episode';

// andalousie a des sceaux vision CORRECTS (pas de manifest décalé comme crete)
// → poiThumb lit p.image directement, aucun override pixel-vérifié nécessaire.
const {
  bd, pois, dishes, gems,
  resolveSlot, poi, poiPills, toBeat, carnetRow,
  mapMarkers, allCoords, kmlCount, byKind, proseBlocks,
} = await createEpisode('andalousie', 'seville');

// ——— Composition de l'épisode (jugement éditorial — grammaire Bourdain) ———
// Test Bourdain : qui est derrière ? pourquoi ça compte ? on commande quoi ?
// Réponse complète → scène. Sinon → carnet.
const rinconcillo = poi('el-rinconcillo');
const eiriz = poi('jamones-eiriz');
const giralda = poi('catedral-giralda');

const scenes = [
  {
    id: 'scene-rinconcillo',
    num: 1,
    kicker: 'Calle Gerona · le QUOI',
    title: 'Le plus vieux bar d’Espagne',
    image: 'el-rinconcillo',
    alt: 'Taverne historique El Rinconcillo, Séville',
    intro:
      'El Rinconcillo, ouvert en 1670. Comptoir de bois, jambons au plafond, et l’addition encore marquée à la craie pendant que tu manges. Sept générations qui n’ont jamais jugé bon de moderniser la place.',
    reco:
      'On commande quoi : les espinacas con garbanzos — épinards-pois chiches au cumin. Une recette arabe de 500 ans. Pis tu réalises que les Arabes qui l’ont inventée se sont fait expulser.',
    quote:
      'C’est pas un décor pour Instagram. Ça marche de même depuis 350 ans, à des gens qui savent pas — ou qui veulent pas savoir — d’où ça vient.',
    via: null,
    pills: poiPills(rinconcillo),
  },
  {
    id: 'scene-eiriz',
    num: 2,
    kicker: 'Corteconcepción · l’INCONFORT',
    title: 'Le jamón, c’est pas juste du cochon',
    image: 'dehesa-eiriz',
    alt: 'Cochons ibériques pata negra dans la dehesa',
    intro:
      'Eiriz, une famille à Corteconcepción depuis 1818 — sept générations dans le même secadero. Tu montes dans la Sierra de Aracena, ça sent le chêne pis le porc qui sèche.',
    reco:
      'Le filet de bellota tranché à la main, fin mai, c’est le jamón qui mûrit dans les bodegas naturelles — pas les cochons qui broutent les glands, ça c’est l’automne. Honnêtement, c’est ça la vraie affaire.',
    quote:
      'Sous l’Inquisition, manger du porc en public, c’était la preuve que t’étais pas un Juif ou un Musulman caché. Le plat le plus aimé d’Espagne est né comme un test de loyauté. Tu mords dans une tranche, t’avales cinq siècles de « prouve que t’es des nôtres ».',
    via: null,
    pills: poiPills(eiriz),
  },
  {
    id: 'scene-giralda',
    num: 3,
    kicker: 'Centre · le POURQUOI',
    title: 'La tour qui ne sait pas ce qu’elle est',
    image: 'giralda',
    alt: 'La Giralda et la cathédrale de Séville',
    intro:
      'La Giralda, c’est un minaret. Un vrai, du XIIᵉ, bâti quand Séville était musulmane. Quand les chrétiens ont repris la ville, ils ont pas démoli la tour — ils ont juste vissé un clocher chrétien par-dessus.',
    reco:
      'À voir une fois, tôt à l’ouverture (l’Alcázar fonctionne par fenêtres de 30 minutes). Mais regarde la tour comme il faut : huit siècles de « à qui appartient cette ville » empilés dans une seule structure.',
    quote:
      'Tout ce qui est beau ici a coûté quelque chose à quelqu’un. C’est ça, l’Andalousie : la convivencia pis la Reconquista dans le même cadre.',
    via: null,
    pills: poiPills(giralda),
  },
];

// Beats du cold open carte-scène. Le 1er beat porte LA CONTRADICTION.
// Comme Chania (base → proche → far west) : on BALAIE le territoire pour le mouvement —
// Triana (serré) → le centre monumental (de l'autre bord du fleuve) → le GROS vol vers la
// Sierra de Jabugo (la journée char). La carte voyage, elle reste pas plantée sur le centre.
const mercado = poi('mercado-de-triana');
const betis = poi('calle-betis-puente');
const alcazar = poi('real-alcazar');
const eirizCO = poi('jamones-eiriz');
const cincoJotasCO = poi('cinco-jotas-bodega');
const grutaCO = poi('gruta-de-las-maravillas');

const mapBeats = [
  {
    kicker: 'Le paradoxe',
    body: 'Séville, fin mai. La ville la plus heureuse d’Espagne — flamenco, orangers, la lumière qui rebondit sur la chaux. Pis le marché où tu achètes ton poisson est bâti sur le château où l’Inquisition jugeait les hérétiques. Bienvenue.',
    fly: `${mercado.coords.lat},${mercado.coords.lng},16`,
    targets: ['mercado-de-triana', 'calle-betis-puente'],
    thumb: 'seville-cover',
    thumbAlt: 'Maisons colorées du quartier de Triana, Séville',
    pills: poiPills(mercado),
  },
  {
    kicker: 'L’autre rive — la ville monumentale',
    body: 'Tu traverses le Guadalquivir. L’Alcázar pis la cathédrale : une matinée, à l’ouverture, billets réservés d’avance. Tu décrisses avant que les groupes débarquent — pis tu retournes à Triana, là où le quartier vit pour vrai.',
    fly: `${alcazar.coords.lat},${alcazar.coords.lng},15`,
    targets: ['real-alcazar', 'catedral-giralda'],
    thumb: 'giralda',
    thumbAlt: 'La Giralda et la cathédrale de Séville',
    pills: poiPills(alcazar),
  },
  {
    kicker: 'Le grand large — la Sierra de Jabugo',
    body: 'Là on sort de la ville. Une journée de char, une heure et demie vers le nord-ouest, dans la Sierra de Aracena : la dehesa d’Eiriz, les caves de Cinco Jotas, la grotte d’Aracena. C’est le pèlerinage gras — la vraie raison du voyage.',
    bounds: [eirizCO, cincoJotasCO, grutaCO].map((p) => `${p.coords.lat},${p.coords.lng}`).join(';'),
    targets: ['jamones-eiriz', 'cinco-jotas-bodega', 'gruta-de-las-maravillas'],
    thumb: 'dehesa-eiriz',
    thumbAlt: 'Cochons ibériques pata negra dans la dehesa',
    pills: [
      { label: 'Eiriz · Maps', url: eirizCO.links.maps! },
      { label: 'Cinco Jotas', url: cincoJotasCO.links.official! },
      { label: 'Gruta · Maps', url: grutaCO.links.maps! },
    ],
  },
];

// ——— Le montage (un beat par GROUPE — le trailer du carnet, pas son inventaire) ———
const golondrinas = poi('las-golondrinas');
const casaCuesta = poi('casa-cuesta');
const sobretablas = poi('sobretablas');
const museoJamon = poi('museo-del-jamon-aracena');
const cincoJotas = poi('cinco-jotas-bodega');

const montageBeats = [
  {
    kicker: 'La table qu’on a pas filmée',
    body: 'Trois registres. Las Golondrinas pour la tapa de quartier — tu dis « dame una » et on t’apporte les puntas de solomillo, point. Casa Cuesta pour un vrai rabo de toro dans une maison de 1880. Pis Sobretablas, le repas-événement (Camila Ferraro, Bib Gourmand) — à El Porvenir, prévois le taxi.',
    bounds: [golondrinas, casaCuesta, sobretablas].map((p) => `${p.coords.lat},${p.coords.lng}`).join(';'),
    targets: ['las-golondrinas', 'casa-cuesta', 'sobretablas'],
    thumb: 'rabo-toro',
    thumbAlt: 'Rabo de toro braisé',
    pills: [
      { label: 'Las Golondrinas · Maps', url: golondrinas.links.maps! },
      { label: 'Casa Cuesta', url: casaCuesta.links.official! },
      { label: 'Sobretablas', url: sobretablas.links.official! },
    ],
  },
  {
    kicker: 'Le pèlerinage jamón',
    body: 'Une journée de char vers la Sierra de Aracena. Commence au Musée du jamón pour comprendre la dehesa, puis Cinco Jotas à Jabugo — plus gros, plus marketé qu’Eiriz, mais la cave vaut le coup. Le contraste artisan vs machine, dans la même journée.',
    bounds: [museoJamon, cincoJotas].map((p) => `${p.coords.lat},${p.coords.lng}`).join(';'),
    targets: ['museo-del-jamon-aracena', 'cinco-jotas-bodega'],
    thumb: 'dehesa-eiriz',
    thumbAlt: 'Cochons ibériques pata negra dans la dehesa',
    pills: [
      { label: 'Musée du jamón · Maps', url: museoJamon.links.maps! },
      { label: 'Cinco Jotas', url: cincoJotas.links.official! },
    ],
  },
  {
    kicker: 'Le rituel (boire comme un local)',
    body: 'Le fino bien frais, la manzanilla saline, le vermut de grifo à la pression le dimanche midi (la hora del vermut), le tinto de verano l’après-midi. Pas de sangria — ça, c’est pour les autobus.',
    fly: `${betis.coords.lat},${betis.coords.lng},15`,
    targets: ['calle-betis-puente'],
    thumb: 'fino',
    thumbAlt: 'Verre de fino, vin de Jerez',
    pills: [{ label: 'Le carnet de bouche', url: '#carnet' }],
  },
];

// ——— Carnet (mode terrain — liste dense, liens directs) ———
// Andalousie : pas de plages, mais des `activity` (marché, producteurs) → fondus dans « À voir & faire ».
const carnetGroups = [
  { label: 'Où dormir', items: byKind(['hotel']) },
  { label: 'Où manger', items: byKind(['resto']) },
  { label: 'À voir & faire', items: byKind(['sight', 'activity']) },
];

// ——— Transformation vers les shapes des composants (résolution d'images ici) ———
const coldOpenBeats = mapBeats.map(toBeat);
const montageComponentBeats = montageBeats.map(toBeat);

const sceneData = scenes.map((s) => ({
  id: s.id,
  num: s.num,
  kicker: s.kicker,
  title: s.title,
  imageSrc: resolveSlot(s.image),
  alt: s.alt,
  intro: s.intro,
  reco: s.reco,
  via: s.via,
  quote: s.quote,
  pills: s.pills,
}));

// Carnet : structure unifiée (listes + prose) pour CarnetSection.
const carnetListGroups = carnetGroups.map((g) => {
  const rows: CarnetRow[] = g.items.map(carnetRow);
  if (g.label === 'Où dormir') {
    for (const e of (bd.accomExtras ?? []) as any[]) {
      rows.push({
        thumbSrc: e.image ? resolveSlot(e.image) : undefined,
        thumbAlt: e.name,
        name: e.name,
        price: e.price || undefined,
        blurb: e.blurb,
        pills: (e.links ?? []) as Pill[],
        forcePillRow: true,
      });
    }
  }
  return {
    type: 'list' as const,
    title: g.label,
    rows,
    footer:
      g.label === 'Où manger'
        ? 'Règle d’or : éviter le premier rang de terrasses de Calle Betis avec menus en 5 langues.'
        : undefined,
  };
});
const proseGroups = proseBlocks.map((b: any) => ({
  type: 'prose' as const,
  title: b.label as string,
  body: b.body as string,
  pills: (b.links ?? []) as Pill[],
}));
const dishesGroup = {
  type: 'list' as const,
  title: 'Le carnet de bouche',
  rows: dishes.map((d) => ({
    thumbSrc: d.image ? resolveSlot(d.image) : undefined,
    thumbAlt: d.title,
    thumbFood: true,
    name: d.title,
    blurb: d.body,
    pills: (d.links ?? []) as Pill[],
  })) as CarnetRow[],
};
const gemsGroup = {
  type: 'list' as const,
  title: 'Pépites locales',
  rows: gems.map((g) => ({
    thumbSrc: g.image ? resolveSlot(g.image) : undefined,
    thumbAlt: g.title,
    name: g.title,
    blurb: g.body,
    pills: (g.links ?? []) as Pill[],
  })) as CarnetRow[],
};
// Filtre les groupes-liste VIDES (ex: gems absents en Andalousie) — pas de heading orphelin.
const carnetAllGroups = [...carnetListGroups, ...proseGroups, dishesGroup, gemsGroup].filter(
  (g) => g.type === 'prose' || g.rows.length > 0
);
---

<EpisodeLayout
  title={`${bd.title} — épisode · prototype v3`}
  favicon="🍖"
  palette="andalousie"
  description={bd.subtitle}
  destLabel="Andalousie"
  chapterNum={bd.order}
  chapterTotal={5}
  chapterTitle={bd.title}
  storageKey="proto-seville-mode"
>
  <div class="view-episode">

    <ScrollyMapSection
      ariaLabel="Cold open — la carte"
      markers={mapMarkers}
      openBounds={allCoords}
      mapId="scene-map"
      beats={coldOpenBeats}
    >
      <div class="beat beat-title">
        <div class="beat-card beat-card-title reveal">
          <span class="ep-kicker">Chapitre {bd.order} de 5 · {bd.nights} nuits · {bd.dates}</span>
          <h1 class="ep-title">{bd.title}</h1>
          <p class="ep-sub">{bd.subtitle}</p>
          <span class="scroll-hint" aria-hidden="true">↓</span>
        </div>
      </div>
    </ScrollyMapSection>

    <section class="jalon">
      <blockquote class="jalon-quote reveal">{bd.pullquote}</blockquote>
    </section>

    <SceneSection scenes={sceneData} />

    <ScrollyMapSection
      ariaLabel="Le montage — le reste du chapitre"
      markers={mapMarkers}
      openBounds={allCoords}
      beats={montageComponentBeats}
    >
      <div class="beat beat-title">
        <div class="beat-card beat-card-title reveal">
          <span class="ep-kicker">Le montage</span>
          <h2 class="montage-title">Ce que la caméra a pas eu le temps de filmer</h2>
        </div>
      </div>
    </ScrollyMapSection>

    <section class="outro">
      <div class="outro-inner reveal">
        <span class="ep-kicker">Le reste de Séville</span>
        <p class="outro-body">
          Le Mercado de Triana, les ateliers de céramique, le pèlerinage jamón vers Jabugo —
          les {pois.length} lieux du chapitre, tous avec leurs liens, pis le budget qui s’accumule,
          vivent dans le carnet. L’épisode c’est l’apéro ; le carnet, c’est l’outil.
        </p>
        <button type="button" class="outro-btn" data-mode="carnet">Ouvrir le carnet</button>
        <a class="outro-next" href="/andalousie/#seville">Voir la version v2 →</a>
      </div>
    </section>

  </div>

  <CarnetSection
    title={bd.title}
    dates={bd.dates}
    focus={bd.focus}
    kmlHref="/andalousie/seville.kml"
    kmlDownload="seville.kml"
    kmlCount={kmlCount}
    markers={mapMarkers}
    openBounds={allCoords}
    groups={carnetAllGroups}
  />
</EpisodeLayout>
