---
// ChapterCover.astro — ARCHITECTURE §4
// Contrepartie v1 : scripts/migrate/fixtures/crete/index.html (.chapter-cover)
interface Props {
  title: string;
  subtitle: string;
  kicker?: string;
  order: number;
  totalBases?: number;
  dates?: string;
  nights?: number;
  imageUrl?: string;
}

const { title, subtitle, kicker, order, totalBases, dates, nights, imageUrl } = Astro.props;

// chapter-num v1 : « 01 / 04 · Base 1 · 5–12 septembre · 8 nuits »
const pad = (n: number) => String(n).padStart(2, '0');
const chapterNum = [
  totalBases ? `${pad(order)} / ${pad(totalBases)}` : pad(order),
  `Base ${order}`,
  dates,
  nights ? `${nights} nuits` : undefined,
]
  .filter(Boolean)
  .join(' · ');
---

<div
  class="chapter-cover"
  style={imageUrl
    ? `background-image: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.35) 35%, rgba(0,0,0,0.82) 100%), url('${imageUrl}');`
    : undefined}
>
  {imageUrl && <img src={imageUrl} alt="" role="presentation" loading="lazy" />}
  <div class="chapter-cover-inner">
    <span class="chapter-num">{chapterNum}</span>
    <h2 class="chapter-title">{title}</h2>
    <p class="chapter-subtitle">{subtitle}</p>
  </div>
</div>

<style>
  .chapter-cover {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    height: 78vh;
    min-height: 520px;
    max-height: 780px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    color: #fff;
    background: var(--deep);
    background-size: cover;
    background-position: center;
  }

  .chapter-cover img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    filter: brightness(0.78) saturate(1.05);
  }

  .chapter-cover::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.35) 35%, rgba(0,0,0,0.82) 100%),
      linear-gradient(to right, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0.15) 55%, transparent 100%);
    z-index: 1;
  }

  .chapter-cover-inner {
    position: relative;
    z-index: 2;
    max-width: var(--max-w);
    width: 100%;
    margin: 0 auto;
    padding: 0 24px 72px;
  }

  .chapter-num {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    display: block;
    margin-bottom: 18px;
  }

  .chapter-num::before {
    content: '';
    display: inline-block;
    width: 40px;
    height: 1px;
    background: rgba(255,255,255,0.6);
    vertical-align: middle;
    margin-right: 14px;
  }

  .chapter-title {
    font-family: var(--font-serif);
    font-size: clamp(56px, 10vw, 128px);
    font-weight: 300;
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin: 0 0 20px;
    color: #fff;
    text-shadow: 0 2px 24px rgba(0,0,0,0.5);
  }

  .chapter-subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(18px, 2.4vw, 26px);
    font-weight: 300;
    max-width: 560px;
    line-height: 1.45;
    color: rgba(255,255,255,0.95);
    text-shadow: 0 1px 16px rgba(0,0,0,0.55);
  }

  @media (max-width: 700px) {
    .chapter-cover { height: 72vh; min-height: 440px; }
    .chapter-cover-inner { padding: 0 24px 48px; }
    .chapter-num { font-size: 10px; letter-spacing: 0.24em; }
    .chapter-num::before { width: 24px; margin-right: 10px; }
  }
</style>
