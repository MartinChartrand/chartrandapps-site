---
// CarnetSection — le mode terrain (ADR-3/5) : liste dense en ordre éditorial, vignettes,
// pills (toute reco = lien cliquable), mini-carte qui suit le scroll (script dans EpisodeLayout),
// export KML par chapitre. Purement présentationnel : la page pré-calcule `groups` (résolution
// d'images comprise) — y compris la fusion des accomExtras dans « Où dormir » et les dishes/gems.
import { ui, type UiLang } from '../../lib/ui-strings';
interface Pill { label: string; url: string }
interface Source { creator: string; url: string; date?: string }
interface Row {
  id?: string;          // 'carnet-<poiId>' pour les POI cartographiés
  dataPoi?: string;     // id du POI si onMap (la mini-carte suit le scroll dessus)
  thumbSrc?: string;
  thumbAlt?: string;
  thumbFood?: boolean;  // vignette agrandie (.carnet-thumb-food) pour les plats
  name: string;
  price?: string;
  blurb?: string;
  story?: string;       // récit sourcé (ADR-5) — dépliable « le récit » ; absent => pas de toggle
  sources?: Source[];   // provenance affichée sous le récit déplié
  pills: Pill[];
  forcePillRow?: boolean; // POI/hébergements : <div class="pill-row"> rendu même si vide
}
type Group =
  | { type: 'list'; title: string; rows: Row[]; footer?: string }
  | { type: 'prose'; title: string; body: string; pills: Pill[] };
interface Props {
  title: string;
  dates: string;
  focus: string;
  kmlHref: string;
  kmlDownload: string;
  kmlCount: number;
  markers: unknown[];
  openBounds: string;
  groups: Group[];
  lang?: UiLang; // langue du chrome — défaut 'fr', additif
}
const { title, dates, focus, kmlHref, kmlDownload, kmlCount, markers, openBounds, groups, lang = 'fr' } = Astro.props;
const t = ui(lang);
---

<div class="view-carnet" id="carnet">
  <div class="carnet-container">
    <aside class="carnet-aside" aria-label={t.carnetMapAria}>
      <div id="carnet-map" class="carnet-map" data-markers={JSON.stringify(markers)} data-open-bounds={openBounds}></div>
    </aside>
    <div class="carnet-main">
      <header class="carnet-head">
        <span class="ep-kicker">{t.carnetKicker(title, dates)}</span>
        <p class="carnet-sub">{focus}</p>
        <div class="pill-row">
          <a class="pill pill-kml" href={kmlHref} download={kmlDownload}>{t.kmlExport(kmlCount)}</a>
        </div>
        <p class="carnet-kml-hint">
          <strong>{t.kmlHintLead}</strong>{t.kmlHintBefore}<a href="https://mymaps.google.com" target="_blank" rel="noopener">mymaps.google.com</a>{t.kmlHintAfter}
        </p>
      </header>

      {groups.map((g) => (
        g.type === 'list' ? (
          <section class="carnet-group">
            <h2 class="carnet-group-title">{g.title}</h2>
            <ul class="carnet-list">
              {g.rows.map((r) => (
                <li class="carnet-row" id={r.id} data-poi={r.dataPoi}>
                  {r.thumbSrc && (
                    <img class={r.thumbFood ? 'carnet-thumb carnet-thumb-food' : 'carnet-thumb'} src={r.thumbSrc} alt={r.thumbAlt} loading="lazy" decoding="async" />
                  )}
                  <div class="carnet-row-content">
                    <div class="carnet-row-main">
                      <span class="carnet-name">{r.name}</span>
                      {r.price && <span class="carnet-price">{r.price}</span>}
                      {r.blurb && <p class="carnet-blurb">{r.blurb}</p>}
                    </div>
                    {r.story && (
                      <details class="carnet-recit">
                        <summary class="carnet-recit-toggle">{t.storyToggle}</summary>
                        <p class="carnet-recit-prose">{r.story}</p>
                        {r.sources && r.sources.length > 0 && (
                          <p class="carnet-recit-sources">
                            <span class="carnet-recit-srclabel">{t.sourcesLabel}</span>{' '}
                            {r.sources.map((s, i) => (
                              <Fragment>{i > 0 && <span class="carnet-recit-sep"> · </span>}<a class="carnet-recit-src" href={s.url} target="_blank" rel="noopener">{s.creator}</a></Fragment>
                            ))}
                          </p>
                        )}
                      </details>
                    )}
                    {(r.forcePillRow || r.pills.length > 0) && (
                      <div class="pill-row">
                        {r.pills.map((l) => (
                          <a class="pill" href={l.url} target="_blank" rel="noopener">{l.label}</a>
                        ))}
                      </div>
                    )}
                  </div>
                </li>
              ))}
            </ul>
            {g.footer && <p class="carnet-footer">{g.footer}</p>}
          </section>
        ) : (
          <section class="carnet-group">
            <h2 class="carnet-group-title">{g.title}</h2>
            <p class="carnet-blurb">{g.body}</p>
            {g.pills.length > 0 && (
              <div class="pill-row">
                {g.pills.map((l) => (
                  <a class="pill" href={l.url} target="_blank" rel="noopener">{l.label}</a>
                ))}
              </div>
            )}
          </section>
        )
      ))}

      <div class="carnet-tail">
        <button type="button" class="outro-btn" data-mode="episode">{t.backToEpisode}</button>
      </div>
    </div>
  </div>
</div>
