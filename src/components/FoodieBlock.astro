---
// FoodieBlock.astro — ARCHITECTURE §4
// Contrepartie v1 : scripts/migrate/fixtures/crete/index.html (.foodie-block)
// Ne rend rien si dishes est vide
interface Dish {
  id: string;
  title: string;
  body: string;
  image: string;
  links?: Array<{ label: string; url: string; }>;
}

interface ImageEntry { slot: string; file: string; alt: string; }

interface Props {
  dishes: Dish[];
  imageManifest: ImageEntry[];
  dest: string;
  title?: string;
}

const { dishes, imageManifest, dest, title = 'Incontournables foodie' } = Astro.props;

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/**/*.{jpg,jpeg,png,webp}',
  { eager: true }
);

function getImgSrc(slot: string): string | null {
  if (!slot) return null;
  const entry = imageManifest.find((img) => img.slot === slot);
  if (!entry) {
    console.warn(`[images] ${dest}: FoodieBlock — slot "${slot}" absent du manifest images.json`);
    return null;
  }
  const key = `/src/assets/destinations/${dest}/${entry.file}`;
  const src = allImages[key]?.default?.src ?? null;
  if (!src) console.warn(`[images] ${dest}: FoodieBlock — fichier "${entry.file}" introuvable (slot "${slot}")`);
  return src;
}

function getImgAlt(slot: string): string {
  return imageManifest.find((img) => img.slot === slot)?.alt ?? '';
}
---

{dishes.length > 0 && (
  <div class="foodie-block">
    <div class="foodie-title">{title}</div>
    {dishes.map((dish) => {
      const imgSrc = getImgSrc(dish.image);
      return (
        <div class="foodie-item">
          <div class="foodie-item-name">{dish.title}</div>
          <div class="foodie-item-desc">{dish.body}</div>
          {imgSrc && (
            <img
              class="foodie-item-img"
              src={imgSrc}
              alt={getImgAlt(dish.image)}
              loading="lazy"
            />
          )}
        </div>
      );
    })}
  </div>
)}

<style>
  .foodie-block {
    background: linear-gradient(135deg, #FEF9F2 0%, #FDF5EC 100%);
    border: 1px solid color-mix(in oklch, var(--terre) 15%, transparent);
    border-radius: var(--radius);
    padding: 28px;
    margin: 24px 0;
  }

  .foodie-title {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 16px;
  }

  .foodie-item { margin-bottom: 16px; }
  .foodie-item:last-child { margin-bottom: 0; }

  .foodie-item-name { font-weight: 500; font-size: 14px; color: var(--text); }

  .foodie-item-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.65;
    margin-top: 2px;
  }

  .foodie-item-img {
    width: 100%;
    height: 150px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    margin-top: 8px;
    box-shadow: var(--shadow-sm);
  }

  @media (max-width: 600px) {
    .foodie-item-img { height: 120px; }
  }
</style>
