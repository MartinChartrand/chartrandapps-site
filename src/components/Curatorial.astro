---
// Curatorial.astro — ARCHITECTURE §4
// Contrepartie v1 : scripts/migrate/fixtures/crete/index.html (.curatorial)
// Résout [[poi:id]] via replacePoiRefs (refs.mjs) → <a class="place-link">
// Rendu markdown minimal (p, h4, strong, em, lien) sans dépendance externe
import { replacePoiRefs } from '../../scripts/lib/refs.mjs';

interface Poi { id: string; name: string; }

interface Props {
  body: string;
  pois: Poi[];
}

const { body, pois } = Astro.props;

// Map id → nom pour la résolution des liens
const poiMap = new Map(pois.map((p) => [p.id, p.name]));

// 1. Résoudre les refs [[poi:id]] → <a class="place-link">
const withLinks = replacePoiRefs(body, (id: string) => {
  const name = poiMap.get(id) ?? id;
  return `<a class="place-link" href="#poi-${id}">${name}</a>`;
});

// 2. Micro-parser markdown → HTML
// Supporte : h4, paragraphes, **strong**, _em_, [lien](url)
function mdToHtml(md: string): string {
  return md
    .split(/\n{2,}/)
    .map((block) => {
      const trimmed = block.trim();
      if (!trimmed) return '';
      // H4
      if (trimmed.startsWith('#### ')) {
        return `<h4>${inlineMarkup(trimmed.slice(5))}</h4>`;
      }
      if (trimmed.startsWith('## ') || trimmed.startsWith('# ')) {
        // h2/h3 → traités comme h4 dans le curatorial (style v1)
        const text = trimmed.replace(/^#{1,3}\s+/, '');
        return `<h4>${inlineMarkup(text)}</h4>`;
      }
      return `<p>${inlineMarkup(trimmed)}</p>`;
    })
    .filter(Boolean)
    .join('\n');
}

function inlineMarkup(s: string): string {
  return s
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/_(.+?)_/g, '<em>$1</em>')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="ext-link">$1</a>');
}

const html = mdToHtml(withLinks);
---

<div class="curatorial" set:html={html} />

<style>
  .curatorial {
    max-width: 680px;
    margin: 32px 0 8px;
    font-size: 16px;
    line-height: 1.8;
    color: var(--text);
  }

  .curatorial :global(p) { margin: 0 0 18px; }

  .curatorial :global(p.lede) {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 400;
    line-height: 1.5;
    color: var(--deep);
    margin-bottom: 24px;
  }

  .curatorial :global(h4) {
    font-family: var(--font-serif);
    font-size: 15px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--terre);
    margin: 26px 0 10px;
  }

  .curatorial :global(strong) { color: var(--deep); font-weight: 600; }

  .curatorial :global(> p:first-of-type::first-letter) {
    font-family: var(--font-serif);
    font-size: 68px;
    font-weight: 400;
    float: left;
    line-height: 0.85;
    padding: 6px 10px 0 0;
    color: var(--terre);
  }

  .curatorial :global(.place-link) {
    color: inherit;
    text-decoration: none;
    font-weight: 500;
    border-bottom: 1.5px solid color-mix(in oklch, var(--terre) 38%, transparent);
    padding-bottom: 1px;
    transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
  }

  .curatorial :global(.place-link:hover) {
    color: var(--terre);
    border-bottom-color: var(--terre);
    background-color: color-mix(in oklch, var(--terre) 8%, transparent);
  }

  .curatorial :global(.place-link:focus-visible) {
    outline: 2px solid var(--terre);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .curatorial :global(.ext-link) {
    color: var(--mer);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklch, var(--mer) 30%, transparent);
    transition: color var(--transition), border-color var(--transition);
  }

  .curatorial :global(.ext-link:hover) {
    color: var(--terre);
    border-bottom-color: var(--terre);
  }

  .curatorial :global(.ext-link::after) {
    content: ' ↗';
    font-size: 0.75em;
    opacity: 0.5;
  }
</style>
