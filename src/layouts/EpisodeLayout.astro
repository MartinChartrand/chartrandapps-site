---
// EpisodeLayout — le shell « mode épisode » v3 (ADR-6, v3-generalisation-decisions.md).
// Infra 100% identique entre chapitres : topbar + progression + toggle Épisode/Carnet,
// script (générique : classes + data-attributes, zéro contenu éditorial), CSS de l'épisode.
// Le contenu (scènes, beats, carnet) vit dans la page-chapitre via le <slot/>.
//
// CSS en `is:global` OBLIGATOIRE (PAS le scope Astro par défaut) : les éléments
// (.beat-card, .beat-quote, .scene-map…) sont rendus par des SOUS-composants — un CSS
// scopé au layout porterait un autre data-astro-cid et ne les matcherait pas. Pas de fuite
// vers le v2 : Astro ne bundle ce CSS que sur les pages qui utilisent ce layout (pages épisode).
// Garde-fou : scripts/test/episode-css-global.test.mjs échoue si quelqu'un re-scope ce <style>.
import DestinationLayout from './Destination.astro';

// CSS Leaflet : frontmatter = bundle global. JAMAIS en @import dans <style> (Astro scope → tuiles
// empilées dans un coin — leçon v2, MapSection.astro).
import 'leaflet/dist/leaflet.css';

interface Props {
  title: string;
  favicon: string;
  palette: string;
  description: string;
  destLabel: string;     // « Crète »
  chapterNum: number;    // 1
  chapterTotal: number;  // 4
  chapterTitle: string;  // « Chania »
  storageKey: string;    // clé localStorage du mode (par chapitre)
}
const { title, favicon, palette, description, destLabel, chapterNum, chapterTotal, chapterTitle, storageKey } =
  Astro.props;
---

<DestinationLayout title={title} favicon={favicon} palette={palette} description={description}>
  <div id="proto" data-view="episode" data-storage-key={storageKey}>

    <header class="topbar">
      <div class="topbar-inner">
        <span class="topbar-title">
          <span class="topbar-dest">{destLabel}</span>
          <span class="topbar-sep">·</span>
          Ch. {chapterNum}/{chapterTotal} — {chapterTitle}
        </span>
        <nav class="mode-toggle" aria-label="Mode de consultation">
          <button type="button" class="mode-btn" data-mode="episode" aria-pressed="true">Épisode</button>
          <button type="button" class="mode-btn" data-mode="carnet" aria-pressed="false">Carnet</button>
        </nav>
      </div>
      <div class="progress-rail"><div class="progress-fill" id="progress-fill"></div></div>
    </header>

    <main id="main-content">
      <slot />
    </main>
  </div>
</DestinationLayout>

<script>
  // ——— Toggle Épisode / Carnet (sous-nav par intention) ———
  const proto = document.getElementById('proto')!;
  const STORAGE_KEY = proto.dataset.storageKey ?? 'episode-mode';
  function setMode(mode: string) {
    proto.dataset.view = mode;
    document.querySelectorAll<HTMLButtonElement>('.mode-btn').forEach((b) => {
      b.setAttribute('aria-pressed', String(b.dataset.mode === mode));
    });
    window.scrollTo({ top: 0, behavior: 'auto' });
    if (history.replaceState) history.replaceState(null, '', mode === 'carnet' ? '#carnet' : '#');
    try {
      localStorage.setItem(STORAGE_KEY, mode);
    } catch {}
    document.dispatchEvent(new CustomEvent('proto:modechange', { detail: mode }));
  }
  document.querySelectorAll<HTMLElement>('[data-mode]').forEach((el) => {
    if (el.tagName === 'BUTTON') el.addEventListener('click', () => setMode(el.dataset.mode!));
  });

  // (La hauteur de la topbar est FIXE en CSS — la mesure JS au chargement attrapait
  // le wrap temporaire des fontes fallback → carte 70px trop basse, vu sur iPhone.)
  // Usage répété : on rouvre dans le dernier mode utilisé (le hash explicite gagne).
  let storedMode: string | null = null;
  try {
    storedMode = localStorage.getItem(STORAGE_KEY);
  } catch {}
  if (location.hash === '#carnet' || storedMode === 'carnet') setMode('carnet');

  // ——— Barre de progression (A Trail Tale, version sobre) ———
  const fill = document.getElementById('progress-fill');
  if (fill) {
    const onScroll = () => {
      const h = document.documentElement;
      const max = h.scrollHeight - h.clientHeight;
      fill.style.width = max > 0 ? `${(h.scrollTop / max) * 100}%` : '0%';
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // ——— Cartes Leaflet : cold open + montage (scrolly) et mini-carte du carnet ———
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const parseBounds = (s: string) =>
    s.split(';').map((pair) => pair.split(',').map(Number) as [number, number]);

  import('leaflet').then(({ default: L }) => {
    const GLYPHS: Record<string, string> = { hotel: '🏨', resto: '🍽️', plage: '🏖️', sight: '🏛️' };

    type MarkerData = { id: string; name: string; mapType: string; coords: { lat: number; lng: number } };

    // Carte non interactive : décor piloté par le scroll, pas un widget.
    function buildMap(el: HTMLElement) {
      const markers: MarkerData[] = JSON.parse(el.dataset.markers ?? '[]');
      const map = L.map(el, {
        zoomControl: false,
        dragging: false,
        scrollWheelZoom: false,
        doubleClickZoom: false,
        boxZoom: false,
        keyboard: false,
        touchZoom: false,
        attributionControl: true,
      });
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        maxZoom: 19,
      }).addTo(map);

      const markerById = new Map<string, ReturnType<typeof L.marker>>();
      const coordsById = new Map<string, [number, number]>();
      markers.forEach((m) => {
        const glyph = GLYPHS[m.mapType] ?? '📍';
        const icon = L.divIcon({
          html: `<span class="map-glyph" aria-label="${m.mapType}">${glyph}</span>`,
          className: 'map-marker',
          iconSize: [32, 32],
          iconAnchor: [16, 16],
        });
        const marker = L.marker([m.coords.lat, m.coords.lng], { icon }).addTo(map);
        // Tooltip permanente JAMAIS fermée côté Leaflet (bug connu : une tooltip
        // permanent fermée se rouvre après un zoom — vécu sur iPhone, les 15 d'un
        // coup). On la laisse « ouverte » et on contrôle la visibilité en CSS.
        marker.bindTooltip(m.name, {
          permanent: true,
          direction: 'top',
          offset: [0, -16],
          className: 'map-tip tip-hidden',
        });
        markerById.set(m.id, marker);
        coordsById.set(m.id, [m.coords.lat, m.coords.lng]);
      });

      // Focus par beat/rangée : halo + nom sur les cibles, les autres estompés
      function focusTargets(ids: string[]) {
        const hasFocus = ids.length > 0;
        markerById.forEach((marker, id) => {
          const active = ids.includes(id);
          marker.setOpacity(hasFocus && !active ? 0.35 : 1);
          const el2 = marker.getElement();
          if (el2) el2.classList.toggle('is-active', active);
          const tipEl = marker.getTooltip()?.getElement();
          if (tipEl) tipEl.classList.toggle('tip-hidden', !active);
        });
      }

      const openBounds = parseBounds(el.dataset.openBounds ?? '');
      const fitOpen = () => map.fitBounds(L.latLngBounds(openBounds), { padding: [40, 40] });
      fitOpen();
      new ResizeObserver(() => map.invalidateSize()).observe(el);
      if (document.readyState !== 'complete') {
        window.addEventListener('load', () => { map.invalidateSize(); fitOpen(); }, { once: true });
      }
      return { map, focusTargets, coordsById, fitOpen, openBounds };
    }

    // — Sections scrollytellées (cold open + montage), chacune sa carte et ses beats.
    // Activation quand la CARTE DE TEXTE entre dans la bande centrale — pas le
    // conteneur .beat (90svh) : en scroll rapide la caméra volait vers le beat
    // suivant pendant que le texte affiché était encore le précédent (vérifié pinchtab).
    // Mobile : la carte de texte occupe le bas de l'écran — on décale la cible du
    // flyTo vers le bas pour que le marker + son étiquette atterrissent dans le
    // HAUT visible, au-dessus de la carte (feedback iPhone : « les cartes cachent
    // le fan out »). Bounds : padding bas asymétrique, même raison.
    const mobile = window.matchMedia('(max-width: 640px)').matches;

    document.querySelectorAll<HTMLElement>('.scrolly-map').forEach((section) => {
      const mapEl = section.querySelector<HTMLElement>('.scene-map');
      if (!mapEl) return;
      const { map, focusTargets, fitOpen, openBounds } = buildMap(mapEl);
      const flyOpts = { duration: reduced ? 0 : 1.6 };

      function flyPoint(lat: number, lng: number, zoom: number) {
        let center: any = [lat, lng];
        if (mobile) {
          const px = map.project([lat, lng], zoom).add([0, map.getSize().y * 0.18] as any);
          center = map.unproject(px, zoom);
        }
        reduced ? map.setView(center, zoom) : map.flyTo(center, zoom, flyOpts);
      }
      function flyBounds(b: ReturnType<typeof L.latLngBounds>, base: number) {
        const pad = mobile
          ? { paddingTopLeft: [30, 70] as any, paddingBottomRight: [30, Math.round(map.getSize().y * 0.38)] as any }
          : { padding: [base, base] as any };
        reduced ? map.fitBounds(b, pad) : map.flyToBounds(b, { ...pad, ...flyOpts });
      }

      const beatObs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const el = (entry.target as HTMLElement).closest<HTMLElement>('.beat')!;
            focusTargets((el.dataset.targets ?? '').split(',').filter(Boolean));
            if (el.dataset.fly) {
              const [lat, lng, zoom] = el.dataset.fly.split(',').map(Number);
              flyPoint(lat, lng, zoom);
            } else if (el.dataset.bounds) {
              flyBounds(L.latLngBounds(parseBounds(el.dataset.bounds)), 60);
            } else {
              flyBounds(L.latLngBounds(openBounds), 40);
            }
          });
        },
        { rootMargin: '-35% 0px -35% 0px' }
      );
      section
        .querySelectorAll<HTMLElement>('.beat')
        .forEach((b) => beatObs.observe(b.querySelector('.beat-card, .beat-quote') ?? b));
    });

    // — Mini-carte du carnet : suit le scroll de la liste (browse spatial rapide).
    // Init paresseuse : Leaflet dans un conteneur display:none mesure 0×0.
    let carnetReady = false;
    function initCarnetMap() {
      if (carnetReady) return;
      const el = document.getElementById('carnet-map');
      // offsetParent est null pour un élément fixed → on teste le MODE, pas le layout
      if (!el || proto.dataset.view !== 'carnet') return;
      carnetReady = true;
      const { map, focusTargets, coordsById } = buildMap(el);
      setTimeout(() => map.invalidateSize(), 400); // conteneur fixed + iOS : recale les tuiles
      const rowObs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const id = (entry.target as HTMLElement).dataset.poi!;
            focusTargets([id]);
            const c = coordsById.get(id);
            if (c) map.setView(c, Math.max(map.getZoom(), 12), { animate: !reduced });
          });
        },
        { rootMargin: '-30% 0px -55% 0px' }
      );
      document.querySelectorAll<HTMLElement>('[data-poi]').forEach((r) => rowObs.observe(r));
    }
    document.addEventListener('proto:modechange', (e) => {
      if ((e as CustomEvent).detail === 'carnet') initCarnetMap();
    });
    initCarnetMap(); // si la page s'ouvre déjà en mode carnet (hash ou mémoire)
  });
</script>

<style is:global>
  /* ——— Vues ——— */
  #proto[data-view='episode'] .view-carnet { display: none; }
  #proto[data-view='carnet'] .view-episode { display: none; }

  /* ——— Barre fixe ——— */
  .topbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: color-mix(in oklch, var(--deep) 88%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  /* En carnet, la barre devient opaque : rien ne doit transparaître sous les
     éléments fixes (feedback iPhone). L'épisode garde le verre fumé. */
  #proto[data-view='carnet'] .topbar {
    background: var(--deep);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }
  .topbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    height: 46px; /* hauteur FIXE : le titre tronque (ellipsis), rien ne wrappe —
                     la carte du carnet se positionne en CSS pur, zéro mesure JS */
    padding: 0 16px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .topbar-title {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .topbar-dest { color: var(--terre); }
  .topbar-sep { opacity: 0.4; margin: 0 4px; }
  .mode-toggle {
    display: flex;
    gap: 0;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 20px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .mode-btn {
    appearance: none;
    border: none;
    background: transparent;
    color: rgba(255, 255, 255, 0.75);
    font-family: var(--font-sans);
    font-size: 12px;
    padding: 6px 16px;
    cursor: pointer;
    min-height: 32px;
  }
  .mode-btn[aria-pressed='true'] {
    background: var(--terre);
    color: white;
  }
  .progress-rail { height: 2px; background: rgba(255, 255, 255, 0.12); }
  .progress-fill { height: 100%; width: 0; background: var(--terre); }

  /* ——— Scrollytelling (carte + scènes) ——— */
  .scrolly { position: relative; }
  .scrolly-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    height: 100svh;
    overflow: hidden;
  }
  .beats {
    position: relative;
    z-index: 2;
    margin-top: -100vh;
    margin-top: -100svh;
    pointer-events: none; /* le scroll passe ; ré-activé sur les cartes */
  }
  .beat {
    min-height: 90vh;
    min-height: 90svh;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 0 16px 12vh;
  }
  .beat-title {
    min-height: 100vh;
    min-height: 100svh;
    align-items: center;
    justify-content: center;
  }
  .beat-card {
    pointer-events: auto;
    max-width: 420px;
    background: color-mix(in oklch, var(--deep) 92%, transparent);
    color: rgba(255, 255, 255, 0.92);
    border-radius: var(--radius);
    padding: 20px 22px;
    box-shadow: var(--shadow-lg);
  }
  .beat-card-title {
    max-width: 560px;
    text-align: center;
    background: color-mix(in oklch, var(--deep) 78%, transparent);
    padding: 36px 32px;
  }
  .ep-kicker {
    display: block;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--terre);
    margin-bottom: 10px;
  }
  .ep-title {
    font-family: var(--font-serif);
    font-size: clamp(48px, 9vw, 84px);
    font-weight: 300;
    line-height: 1;
    color: white;
  }
  .ep-sub {
    margin-top: 14px;
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
  }
  .scroll-hint {
    display: block;
    margin-top: 18px;
    font-size: 18px;
    color: rgba(255, 255, 255, 0.6);
    animation: hint 2s ease-in-out infinite;
  }
  @keyframes hint { 50% { transform: translateY(6px); } }
  @media (prefers-reduced-motion: reduce) { .scroll-hint { animation: none; } }

  .beat-thumb {
    display: block;
    width: calc(100% + 44px);
    margin: -20px -22px 14px;
    height: 150px;
    object-fit: cover;
    border-radius: var(--radius) var(--radius) 0 0;
  }
  .beat-kicker {
    display: block;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--terre);
    margin-bottom: 8px;
  }
  .beat-body { font-size: 15px; line-height: 1.7; }
  .scene-title {
    font-family: var(--font-serif);
    font-size: clamp(30px, 5vw, 42px);
    font-weight: 300;
    line-height: 1.1;
    color: white;
  }
  .montage-title {
    font-family: var(--font-serif);
    font-size: clamp(26px, 4.5vw, 38px);
    font-weight: 300;
    font-style: italic;
    line-height: 1.2;
    color: white;
  }
  .scene-via {
    display: inline-block;
    margin-top: 10px;
    font-size: 12px;
    color: var(--terre);
    text-decoration: none;
    border-bottom: 1px dotted var(--terre);
  }
  .scene-via:hover { color: white; border-color: white; }
  .beat-quote {
    pointer-events: auto;
    max-width: 520px;
    font-family: var(--font-serif);
    font-size: clamp(22px, 4vw, 30px);
    font-weight: 300;
    font-style: italic;
    line-height: 1.4;
    color: white;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.6);
    border-left: 3px solid var(--terre);
    padding-left: 18px;
  }

  /* Carte-scène */
  .scene-map { position: absolute; inset: 0; background: var(--sand); }
  .map-scrim {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(to bottom, rgba(26, 42, 58, 0.35), transparent 30%, transparent 75%, rgba(26, 42, 58, 0.35));
    z-index: 500; /* au-dessus des tuiles Leaflet (400), sous les beats */
  }

  /* Scènes storybook */
  .scene-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .scene-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(26, 42, 58, 0.45), rgba(26, 42, 58, 0.1) 40%, rgba(26, 42, 58, 0.55));
  }

  /* Pills — toute reco = lien cliquable */
  .pill-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
  .pill {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    font-size: 12px;
    padding: 5px 14px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: white;
    text-decoration: none;
    transition: background var(--transition);
  }
  .pill:hover { background: var(--terre); border-color: var(--terre); }

  /* ——— Jalon ——— */
  .jalon {
    background: var(--deep);
    padding: 18vh 24px;
    display: flex;
    justify-content: center;
  }
  .jalon-quote {
    max-width: 680px;
    font-family: var(--font-serif);
    font-size: clamp(24px, 4.5vw, 36px);
    font-weight: 300;
    font-style: italic;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.95);
    text-align: center;
  }

  /* ——— Outro ——— */
  .outro {
    background: var(--deep);
    padding: 16vh 24px;
    display: flex;
    justify-content: center;
    text-align: center;
  }
  .outro-inner { max-width: 520px; }
  .outro-body { color: rgba(255, 255, 255, 0.85); font-size: 15px; line-height: 1.75; }
  .outro-btn {
    appearance: none;
    border: none;
    margin-top: 24px;
    background: var(--terre);
    color: white;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    padding: 12px 28px;
    border-radius: 24px;
    cursor: pointer;
    min-height: 44px;
  }
  .outro-btn:hover { background: var(--accent); }
  .outro-next {
    display: block;
    margin-top: 20px;
    color: rgba(255, 255, 255, 0.6);
    font-size: 13px;
    text-decoration: none;
  }
  .outro-next:hover { color: white; }

  /* ——— Carnet (terrain : clair, dense, gros tap targets) ——— */
  .view-carnet { background: var(--bg); min-height: 100vh; }
  .carnet-container {
    max-width: 1080px;
    margin: 0 auto;
    padding: 76px 16px 64px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: 32px;
  }
  .carnet-main { order: 1; min-width: 0; }
  .carnet-aside { order: 2; }
  .carnet-map {
    position: sticky;
    top: 64px;
    height: min(72vh, 560px);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--sand);
    border: 1px solid var(--border);
  }
  @media (max-width: 900px) {
    /* iOS Safari + sticky + viewport dynamique = carte qui flotte (vu sur iPhone).
       FIXED : la carte est soudée sous la bande Épisode/Carnet, la liste passe
       dessous sans jamais transparaître. */
    /* topbar = 46px inner + 2px rail = 48px, FIXE (voir .topbar-inner) */
    .carnet-container { display: block; padding-top: 0; }
    .carnet-aside {
      position: fixed;
      top: 48px;
      left: 0;
      right: 0;
      z-index: 50;
      margin: 0;
      background: var(--bg);
      box-shadow: 0 8px 14px -10px rgba(26, 42, 58, 0.45);
    }
    .carnet-map {
      position: static;
      height: 150px;
      border-radius: 0;
      border-left: none;
      border-right: none;
      border-top: none;
    }
    .carnet-main {
      padding-top: 212px; /* 48 topbar + 150 carte + 14 respiration */
    }
  }
  .carnet-head { margin-bottom: 28px; }
  .carnet-sub { color: var(--muted); font-size: 13px; margin-top: 4px; }
  .carnet-kml-hint { font-size: 12px; color: var(--muted); margin-top: 8px; }
  .carnet-kml-hint a { color: var(--mer); }
  .view-carnet .pill-kml { background: var(--deep); color: white; }
  .view-carnet .pill-kml:hover { background: var(--terre); }
  .carnet-group { margin-bottom: 34px; }
  .carnet-group-title {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 12px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border);
  }
  .carnet-list { list-style: none; }
  .carnet-row {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
  }
  .carnet-row:last-child { border-bottom: none; }
  .carnet-row-content { flex: 1; min-width: 0; }
  .carnet-thumb {
    flex-shrink: 0;
    width: 86px;
    height: 86px;
